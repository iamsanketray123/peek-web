// Peek Web — Prisma schema.
// Auth (users, sessions) is handled by Supabase Auth (auth.users).
// We store only application data here, keyed by the Supabase user id (UUID).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (pgbouncer) for serverless runtime
  directUrl = env("DIRECT_URL")   // direct connection for migrations / db push
}

/// A keyword a user has saved/tracked from the Keyword Explorer.
model SavedKeyword {
  id             String   @id @default(cuid())
  userId         String // Supabase auth.users.id
  term           String
  country        String   @default("us")
  popularity     Int?
  difficulty     Int?
  opportunity    Int?
  classification String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, term, country])
  @@index([userId])
}

/// An App Store app a user is tracking (Phase 3 — App Tracking).
model TrackedApp {
  id           String       @id @default(cuid())
  userId       String // Supabase auth.users.id
  appleId      String // iTunes trackId
  name         String
  developer    String
  iconUrl      String?
  primaryGenre String?
  country      String       @default("us")
  ratingCount  Int          @default(0)
  avgRating    Float        @default(0)
  price        String?
  releaseDate  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  keywords     AppKeyword[]
  competitors  CompetitorApp[]
  seedStatus   String       @default("pending") // "pending" | "seeding" | "completed" | "error"

  @@unique([userId, appleId, country])
  @@index([userId])
}

/// A competitor app associated with a tracked workspace app.
model CompetitorApp {
  id           String     @id @default(cuid())
  trackedAppId String
  trackedApp   TrackedApp @relation(fields: [trackedAppId], references: [id], onDelete: Cascade)
  appleId      String
  name         String
  developer    String
  iconUrl      String?
  createdAt    DateTime   @default(now())
  snapshots    CompetitorRankSnapshot[]

  @@unique([trackedAppId, appleId])
  @@index([trackedAppId])
}

/// A keyword tracked for a specific app, with the latest computed metrics.
model AppKeyword {
  id               String         @id @default(cuid())
  appId            String
  app              TrackedApp     @relation(fields: [appId], references: [id], onDelete: Cascade)
  term             String
  popularity       Int?
  difficulty       Int?
  difficultyLabel  String?
  metricsUpdatedAt DateTime?
  createdAt    DateTime       @default(now())
  snapshots    RankSnapshot[]
  competitorSnapshots CompetitorRankSnapshot[]

  @@unique([appId, term])
  @@index([appId])
}

/// A point-in-time rank of an app for one of its tracked keywords.
/// position is null when the app isn't found in the search results (not ranked).
model RankSnapshot {
  id           String     @id @default(cuid())
  appKeywordId String
  appKeyword   AppKeyword @relation(fields: [appKeywordId], references: [id], onDelete: Cascade)
  position     Int? // 1-based rank; null = not ranked
  checkedAt    DateTime   @default(now())

  @@index([appKeywordId, checkedAt])
}

/// A point-in-time rank of a competitor app for one of the main app's tracked keywords.
model CompetitorRankSnapshot {
  id              String        @id @default(cuid())
  competitorId    String
  competitor      CompetitorApp @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  appKeywordId    String
  appKeyword      AppKeyword    @relation(fields: [appKeywordId], references: [id], onDelete: Cascade)
  position        Int? // 1-based rank; null = not ranked
  checkedAt       DateTime      @default(now())

  @@index([competitorId, checkedAt])
  @@index([appKeywordId, checkedAt])
}
